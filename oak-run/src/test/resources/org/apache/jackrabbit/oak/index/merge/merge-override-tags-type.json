{
  "build": {
    "/oak:index/lucene-2": {
      "jcr:primaryType": "nam:oak:QueryIndexDefinition",
      ":version": 2,
      "tags": ["similarity", "asset", "fragments"],
      "type": "elasticsearch",
      "async": "elastic-async",
      "reindex": false,
      "reindexCount": 1
    }
  },

  "run": {
    "/oak:index/lucene-1": {
      "jcr:primaryType": "nam:oak:QueryIndexDefinition",
      ":version": 2,
      "tags": ["similarity", "asset"],
      "type": "disabled",
      "async": ["async", "nrt"],
      "reindex": false,
      "reindexCount": 1
    },
    "/oak:index/lucene-1-custom-1": {
      "jcr:primaryType": "nam:oak:QueryIndexDefinition",
      ":version": 2,
      "tags": "custom",
      "type": "lucene",
      "async": "async",
      "reindex": false,
      "reindexCount": 1,
      "merges": ["/oak:index/lucene-1", "/oak:index/lucene-0-custom-1"]
    }
  },

  "expected": {
    "/oak:index/lucene-2": {
      "jcr:primaryType": "nam:oak:QueryIndexDefinition",
      ":version": 2,
      "tags": ["similarity", "asset", "fragments"],
      "type": "elasticsearch",
      "async": "elastic-async",
      "reindex": false,
      "reindexCount": 1
    },
    "/oak:index/lucene-2-custom-1": {
      "jcr:primaryType": "nam:oak:QueryIndexDefinition",
      "tags": ["asset", "custom", "fragments", "similarity"],
      "type": "elasticsearch",
      "async": "elastic-async",
      "merges": ["/oak:index/lucene-2", "/oak:index/lucene-1-custom-1"]
    }
  }
}
